<link rel="icon" type="image/png" sizes="32x32" href="data:image/png;base64,">
<link rel="apple-touch-icon" sizes="180x180" href="data:image/png;base64,">
<meta name="theme-color" content="#2f4f48">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Hanken+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --sand:#eadfce;--paper:#f7f2ea;--ink:#2e2a24;--ink-soft:#6f675b;
    --ocean:#3f6b60;--ocean-deep:#2f4f48;--coral:#c8805f;--gold:#d6a35c;
    --line:rgba(46,42,36,.12);--radius:16px;--radius-sm:10px;
    --shadow:0 18px 48px -24px rgba(46,42,36,.45);
    --display:"Fraunces",Georgia,serif;--body:"Hanken Grotesk",system-ui,sans-serif;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:var(--body);color:var(--ink);background:var(--paper);line-height:1.6;-webkit-font-smoothing:antialiased}
  img{display:block;max-width:100%}
  .wrap{max-width:1232px;margin:0 auto;padding:0 clamp(24px,5vw,96px)}

  /* ---------- Lesson booking bar ---------- */
  .booking{position:sticky;top:0;z-index:50;background:rgba(47,79,72,.72);-webkit-backdrop-filter:blur(12px) saturate(115%);backdrop-filter:blur(12px) saturate(115%);border-bottom:1px solid rgba(255,255,255,.14);color:#f7f2ea}
  .booking-inner{display:flex;flex-wrap:wrap;align-items:center;gap:14px;padding:14px clamp(24px,5vw,96px);max-width:1232px;margin:0 auto}
  .booking .brand{font-family:var(--display);font-weight:600;font-size:18px;margin-right:auto;display:flex;align-items:center;gap:9px}
  .booking .brand small{font-family:var(--body);font-weight:400;font-size:11px;letter-spacing:.16em;text-transform:uppercase;opacity:.7;display:block;margin-top:-2px}
  .booking .brand-logo-lock{height:46px;width:auto;display:block;filter:drop-shadow(0 1px 2px rgba(0,0,0,.25))}
  .mainnav{display:flex;align-items:center;gap:22px}
  .mainnav a{color:#f3ede2;text-decoration:none;font-size:14px;font-weight:500;opacity:.9;padding:4px 2px;border-bottom:2px solid transparent;transition:border-color .15s,opacity .15s}
  .mainnav a:hover{opacity:1;border-bottom-color:var(--gold)}
  .navtoggle{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;align-self:center}
  .navtoggle span{display:block;width:24px;height:2px;background:#f3ede2;border-radius:2px}
  .field{display:flex;flex-direction:column;gap:4px}
  .field label{font-size:10px;letter-spacing:.14em;text-transform:uppercase;opacity:.75}
  .field input,.field select{font-family:var(--body);font-size:14px;border:none;background:rgba(255,255,255,.12);color:#f7f2ea;border-radius:8px;padding:8px 10px;min-width:130px}
  .field input::-webkit-calendar-picker-indicator{filter:invert(1);opacity:.7}
  .field select option{color:#2e2a24}
  .btn{font-family:var(--body);font-weight:600;font-size:14px;border:none;cursor:pointer;border-radius:999px;padding:11px 22px;transition:transform .15s,background .15s;text-decoration:none;display:inline-block}
  .btn:active{transform:scale(.97)}
  .btn-coral{background:var(--coral);color:#fff}.btn-coral:hover{background:#b3704f}
  .btn-ocean{background:var(--ocean-deep);color:#fff;white-space:nowrap}.btn-ocean:hover{background:#26413b}
  .btn-ocean svg{width:16px;height:16px;vertical-align:-3px;margin-right:7px}
  .booking .btn{align-self:flex-end}

  /* ---------- Hero ---------- */
  .hero{position:relative;min-height:clamp(460px,76vh,660px);display:flex;align-items:flex-end;color:#fff;overflow:hidden;background:#233f39}
  .hero::after{content:"";position:absolute;left:0;right:0;bottom:0;height:120px;background:linear-gradient(to bottom,rgba(247,242,234,0),var(--paper));z-index:1;pointer-events:none}
  .hero-poster{position:absolute;inset:0;background:url("data:image/jpeg;base64,") 60% 42%/cover no-repeat;transform:scale(1.04)}
  .hero-video{position:absolute;inset:0;overflow:hidden;pointer-events:none}
  .hero-video iframe{position:absolute;top:50%;left:50%;width:100vw;height:56.25vw;min-height:100%;min-width:177.78vh;transform:translate(-50%,-50%);border:0}
  .hero-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(38,58,52,.2) 0%,rgba(38,58,52,.32) 45%,rgba(38,58,52,.82) 100%)}
  .hero-content{position:relative;z-index:2;padding:0 clamp(24px,5vw,96px) 64px;max-width:1232px;margin:0 auto;width:100%;animation:rise .9s cubic-bezier(.2,.7,.2,1) both}
  .eyebrow{font-size:12px;letter-spacing:.22em;text-transform:uppercase;font-weight:600;opacity:.9;display:flex;align-items:center;gap:10px;margin-bottom:18px}
  .eyebrow::before{content:"";width:34px;height:1px;background:rgba(255,255,255,.7)}
  .hero h1{font-family:var(--display);font-weight:500;font-size:clamp(34px,5.4vw,60px);line-height:1.04;letter-spacing:-.5px;max-width:15ch}
  .hero h1 em{font-style:italic;color:#ecc18a}
  .hero p{font-size:clamp(15px,1.6vw,18px);max-width:44ch;margin:18px 0 26px;opacity:.92}
  .hero-cta{display:flex;flex-wrap:wrap;gap:12px;align-items:center}
  .btn-ghost{background:rgba(255,255,255,.12);color:#fff;border:1px solid rgba(255,255,255,.35);backdrop-filter:blur(4px)}
  .btn-ghost:hover{background:rgba(255,255,255,.2)}
  .trust{display:flex;flex-wrap:wrap;gap:22px;margin-top:30px;font-size:13.5px;opacity:.92}
  .trust span{display:flex;align-items:center;gap:8px}.trust svg{width:17px;height:17px;flex:none}

  /* ---------- Lessons ---------- */
  .lessons{padding-top:96px;padding-bottom:40px}
  .sec-head{margin-bottom:30px}
  .sec-head .kick{font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--coral);font-weight:600;margin-bottom:8px}
  .sec-head h2{font-family:var(--display);font-weight:500;font-size:clamp(28px,4vw,40px);letter-spacing:-.4px;line-height:1.05;max-width:18ch}
  .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(248px,1fr));gap:22px}
  .card{background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;display:flex;flex-direction:column;transition:transform .2s,box-shadow .2s}
  .card:hover{transform:translateY(-4px);box-shadow:var(--shadow)}
  .card .ph{aspect-ratio:4/3;background:var(--sand) center/cover no-repeat;position:relative}
  .card .ph svg{position:absolute;inset:0;width:100%;height:100%;display:block}
  .card .ph.icon{display:flex;align-items:center;justify-content:center;background:var(--sand)}
  .card .ph.icon svg{position:static;inset:auto;width:78px;height:78px;color:var(--ocean-deep)}
  .tag{position:absolute;top:12px;left:12px;background:var(--coral);color:#fff;font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;padding:5px 11px;border-radius:999px}
  .card-body{padding:18px 20px 22px;display:flex;flex-direction:column;flex:1}
  .card-top{display:flex;justify-content:space-between;align-items:flex-start;gap:12px}
  .card h3{font-family:var(--display);font-weight:500;font-size:21px;letter-spacing:-.2px;flex:1;min-width:0}
  .price{text-align:right;white-space:nowrap;line-height:1.1;flex-shrink:0}
  .price b{font-family:var(--display);font-weight:600;font-size:24px;color:var(--ocean)}
  .price small{display:block;font-size:11px;color:var(--ink-soft)}
  .card p{font-size:14px;color:var(--ink-soft);margin:10px 0 16px;flex:1}
  .meta{display:flex;align-items:center;gap:7px;font-size:12.5px;color:var(--ocean);font-weight:500;padding-top:13px;border-top:1px solid var(--line)}
  .meta svg{width:16px;height:16px}

  /* ---------- Prices ---------- */
  .prices{padding-top:14px;padding-bottom:6px}
  .sec-note{font-size:14.5px;color:var(--ink-soft);max-width:62ch;margin-top:12px;line-height:1.6}
  .price-cat{font-family:var(--display);font-weight:500;font-size:22px;color:var(--ink);margin:40px 0 16px;letter-spacing:-.2px}
  .price-cat span{font-family:var(--body);font-weight:500;font-size:13px;letter-spacing:.03em;color:var(--ink-soft)}
  .price-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:14px}
  .ptier{background:var(--paper);border:1px solid var(--line);border-radius:var(--radius-sm);padding:18px 16px 16px;position:relative}
  .ptier .pt-name{font-size:13px;color:var(--ink-soft);font-weight:600;letter-spacing:.02em;margin-bottom:9px}
  .ptier .pt-price{font-family:var(--display);font-weight:600;font-size:30px;line-height:1;color:var(--ocean)}
  .ptier .pt-sub{font-size:12.5px;color:var(--ink-soft);margin-top:7px}
  .ptier.feat{background:var(--ocean-deep);border-color:var(--ocean-deep)}
  .ptier.feat .pt-name{color:rgba(247,242,234,.72)}
  .ptier.feat .pt-price{color:#f0b86b}
  .ptier.feat .pt-sub{color:rgba(247,242,234,.72)}
  .ptier-tag{position:absolute;top:-9px;right:12px;background:var(--coral);color:#fff;font-size:10px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;padding:4px 9px;border-radius:999px}
  .ptable-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch}
  .ptable{width:100%;border-collapse:collapse;font-size:14px;min-width:430px}
  .ptable th,.ptable td{padding:12px;text-align:center;border-bottom:1px solid var(--line);white-space:nowrap}
  .ptable thead th{font-size:11.5px;text-transform:uppercase;letter-spacing:.07em;color:var(--ink-soft);font-weight:600}
  .ptable th:first-child,.ptable td:first-child{text-align:left}
  .ptable tbody td{color:var(--ocean);font-weight:600}
  .ptable tbody td:first-child{color:var(--ink)}
  .price-foot{font-size:13.5px;color:var(--ink-soft);margin-top:14px;max-width:68ch;line-height:1.6}
  .price-rules{margin-top:16px;display:grid;gap:8px}
  .price-rules p{font-size:13px;color:var(--ink-soft);line-height:1.6;max-width:82ch}
  .price-rules strong{color:var(--ink);font-weight:600}
  .book-cta{margin-top:40px;background:var(--ocean-deep);border-radius:var(--radius);padding:30px 32px;display:flex;flex-wrap:wrap;gap:20px 30px;align-items:center;justify-content:space-between}
  .book-cta h3{font-family:var(--display);font-weight:500;font-size:22px;color:#fff;letter-spacing:-.2px}
  .book-cta p{font-size:14.5px;color:rgba(247,242,234,.82);margin-top:9px;max-width:54ch;line-height:1.6}
  .book-actions{display:flex;flex-wrap:wrap;align-items:center;gap:16px}
  .book-actions .call{color:rgba(247,242,234,.85);text-decoration:none;font-weight:600;font-size:14px;white-space:nowrap}
  .book-actions .call:hover{color:#fff}

  /* ---------- Instructor ---------- */
  .pedro{display:grid;grid-template-columns:1fr 1.15fr;gap:36px;align-items:stretch;margin:78px 0;background:var(--sand);border-radius:24px;overflow:hidden}
  .pedro .gallery{position:relative;overflow:hidden;background:var(--sand);min-height:420px}
  .pedro .gallery .slide{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 30%;opacity:0;transition:opacity .6s ease}
  .pedro .gallery .slide.active{opacity:1}
  .pedro .gallery .gnav{position:absolute;top:50%;transform:translateY(-50%);border:none;width:38px;height:38px;border-radius:50%;background:rgba(255,255,255,.82);color:var(--ink);font-size:24px;line-height:0;cursor:pointer;display:grid;place-items:center;box-shadow:0 2px 10px rgba(0,0,0,.12);transition:background .2s,transform .2s;z-index:2}
  .pedro .gallery .gnav:hover{background:#fff;transform:translateY(-50%) scale(1.06)}
  .pedro .gallery .prev{left:12px}
  .pedro .gallery .next{right:12px}
  .pedro .gallery .dots{position:absolute;bottom:14px;left:0;right:0;display:flex;gap:8px;justify-content:center;z-index:2}
  .pedro .gallery .dot{width:9px;height:9px;border-radius:50%;border:none;background:rgba(255,255,255,.65);cursor:pointer;padding:0;transition:background .2s,transform .2s}
  .pedro .gallery .dot.active{background:var(--coral);transform:scale(1.2)}
  .pedro .text{padding:40px 44px 40px 0}
  .pedro .kick{font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--coral);font-weight:600;margin-bottom:10px}
  .pedro h2{font-family:var(--display);font-weight:500;font-size:clamp(26px,3.4vw,36px);letter-spacing:-.3px;line-height:1.08;margin-bottom:14px}
  .pedro p{font-size:15px;color:var(--ink-soft);margin-bottom:14px}
  .pedro .sig{font-family:var(--display);font-style:italic;font-size:19px;color:var(--ink)}
  .pedro .creds-title{font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--coral);font-weight:600;margin:6px 0 12px}
  .pedro .creds{list-style:none;margin:0 0 18px;padding:0;display:grid;gap:9px}
  .pedro .creds li{position:relative;padding-left:26px;font-size:14.5px;color:var(--ink-soft);line-height:1.4}
  .pedro .creds li::before{content:"";position:absolute;left:0;top:2px;width:16px;height:16px;border-radius:50%;background:var(--coral);opacity:.16}
  .pedro .creds li::after{content:"";position:absolute;left:5px;top:7px;width:6px;height:6px;border-radius:50%;background:var(--coral)}

  /* ---------- Stay cross-link ---------- */
  .stay{position:relative;border-radius:24px;overflow:hidden;color:#fff;margin-bottom:78px;min-height:300px;display:flex;align-items:center}
  .stay::before{content:"";position:absolute;inset:0;background:linear-gradient(90deg,rgba(38,58,52,.85) 0%,rgba(38,58,52,.55) 60%,rgba(38,58,52,.35) 100%),url("https://www.supertuboswestsurf.com/wp-content/uploads/2018/03/IMG_8311-Website.jpg") center/cover no-repeat}
  .stay .inner{position:relative;z-index:2;padding:44px}
  .stay .kick{font-size:12px;letter-spacing:.18em;text-transform:uppercase;font-weight:600;opacity:.85;margin-bottom:10px}
  .stay h2{font-family:var(--display);font-weight:500;font-size:clamp(24px,3.2vw,34px);max-width:18ch;line-height:1.1;margin-bottom:10px}
  .stay p{max-width:42ch;opacity:.92;margin-bottom:22px}

  /* ---------- Footer ---------- */
  footer{background:var(--ocean-deep);color:#dfeae6;padding:40px 0}
  .foot{display:flex;flex-wrap:wrap;gap:24px;justify-content:space-between;align-items:center}
  .foot .brand{font-family:var(--display);font-size:20px;color:#fff}
  .foot a{color:#dfeae6;text-decoration:none}.foot a:hover{color:#fff}
  .foot .contact{font-size:14px;line-height:1.9}
  .foot .ig{display:flex;align-items:center;gap:8px;margin-top:14px;font-weight:600}
  .foot .addr{display:flex;align-items:flex-start;gap:8px;margin-top:12px;max-width:280px;line-height:1.45}
  .foot .addr svg{width:17px;height:17px;flex:none;margin-top:1px}
  .foot-map{margin-top:30px}
  .foot-credit{margin-top:30px;padding-top:22px;border-top:1px solid rgba(255,255,255,.12);text-align:center;font-size:13px;color:rgba(223,234,230,.72)}
  .foot-credit a{color:var(--coral);text-decoration:none;font-weight:600}
  .foot-credit a:hover{text-decoration:underline}
  .foot-map iframe{width:100%;height:210px;border:0;border-radius:14px;display:block}
  .foot .ig svg{width:18px;height:18px;flex:none}

  .reviews{padding:6px 0 24px}
  .rev-head{margin-bottom:26px}
  .rev-head .kick{font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--coral);font-weight:600;margin-bottom:8px}
  .rev-head h2{font-family:var(--display);font-weight:500;font-size:clamp(26px,3.4vw,36px);letter-spacing:-.3px;line-height:1.05}
  .rev-rating{margin-top:12px;font-size:14px;color:var(--ink-soft);display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  .rev-rating .stars{color:var(--coral);letter-spacing:2px;font-size:16px}
  .rev-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:20px}
  .rev{margin:0;background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);padding:22px;display:flex;flex-direction:column;gap:12px}
  .rev .stars{color:var(--coral);letter-spacing:2px;font-size:15px}
  .rev p{font-family:var(--display);font-style:italic;font-size:16px;line-height:1.5;color:var(--ink);margin:0;flex:1}
  .rev cite{font-style:normal;font-size:12px;color:var(--ink-soft);letter-spacing:.04em;display:flex;flex-direction:column;gap:3px}
  .rev cite .rev-name{font-weight:600;color:var(--ink);font-size:13px}
  .rev cite .rev-src{display:flex;align-items:center;gap:6px}
  .rev cite svg{width:14px;height:14px}

  .packs-cta{background:var(--ocean-deep);color:#fff;border-radius:var(--radius);padding:28px 32px;margin-top:16px;display:flex;flex-direction:column;gap:10px}
  .packs-cta h4{font-family:var(--display);font-size:20px;font-weight:600;color:#fff;margin:0}
  .packs-cta p{font-size:14px;color:rgba(247,242,234,.8);margin:0;line-height:1.6}
  @media(max-width:760px){.packs-cta{padding:22px 20px}}
  .rev-cta{margin:40px 0 16px;display:flex;justify-content:center}
  @keyframes rise{from{opacity:0;transform:translateY(26px)}to{opacity:1;transform:translateY(0)}}
  @media(max-width:820px){.pedro{grid-template-columns:1fr}.pedro .gallery{aspect-ratio:16/10;min-height:auto}.pedro .text{padding:8px 28px 36px}}
  @media(max-width:760px){
    .booking .brand{width:100%;margin-bottom:4px}
    .field,.booking .btn{flex:1 1 calc(50% - 7px)}
    .field input,.field select{min-width:0;width:100%}
  }
  @media(max-width:760px){.hero-content{padding-top:clamp(32px,7vw,52px)}.mob-br{display:block}}
  .mob-br{display:none}
  @media(prefers-reduced-motion:reduce){*{animation:none!important}.hero-video{display:none}}
  html{scroll-behavior:smooth}
  #lessons,#prices,#about,#reviews,#stay{scroll-margin-top:92px}
  @media(max-width:760px){
    .booking .brand{width:auto;margin-bottom:0;margin-right:auto}
    .navtoggle{display:flex}
    .mainnav{display:none;flex-basis:100%;flex-direction:column;align-items:flex-start;gap:4px;padding:6px 0 2px}
    .mainnav.open{display:flex}
  }

  .lang-switch{display:flex;align-items:center;gap:6px;margin-left:18px;flex-shrink:0}
  .lang-switch span{color:rgba(255,255,255,.35);font-size:13px}
  .lang-switch button{background:none;border:none;color:rgba(255,255,255,.55);font-size:13px;font-weight:700;cursor:pointer;padding:4px 2px;letter-spacing:.06em;font-family:inherit}
  .lang-switch button.on{color:#fff}
  .lang-switch button:hover{color:#fff}
  </style>

<script type="application/ld+json">
{
