<script define:vars={{ i18n }}>

window.setLang = function setLang(l) {
  const d = i18n[l];
  document.documentElement.lang = l;
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const k = el.dataset.i18n;
    if (d[k] !== undefined) el.innerHTML = d[k];
  });
  document.querySelectorAll('#langSwitch button').forEach(b => {
    b.classList.toggle('on', b.textContent.toLowerCase() === l);
  });
  try { localStorage.setItem('lang',''); } catch(e){}
  // Seitentitel + Meta-Description je Sprache
  document.title = l === 'pt'
    ? 'Peniche On Surf — Escola de Surf & Aluguer · Peniche / Supertubos'
    : 'Peniche On Surf — Surf School & Rentals · Peniche / Supertubos';
  var metaDesc = document.querySelector('meta[name="description"]');
  if (metaDesc) {
    metaDesc.setAttribute('content', l === 'pt'
      ? 'Aprende a surfar em Supertubos e Baleal com a Peniche On Surf. Treino personalizado com o instrutor local Pedro, equipamento incluído, todos os níveis. Aulas, treinos e aluguer de prancha e fato.'
      : 'Learn to surf at Supertubos & Baleal with Peniche On Surf. Personal coaching with local instructor Pedro, all gear included, all levels welcome. Lessons, training, board & wetsuit rentals.');
  }
}
</script>

<script>
(function(){
  var g = document.getElementById('pedroGallery');
  if(!g) return;
  var slides = g.querySelectorAll('.slide');
  var dots   = g.querySelectorAll('.dot');
  var cur = 0, timer;
  function show(i){
    cur = (i + slides.length) % slides.length;
    slides.forEach(function(s,n){ s.classList.toggle('active', n===cur); });
    dots.forEach(function(d,n){
      d.classList.toggle('active', n===cur);
      d.setAttribute('aria-selected', n===cur ? 'true' : 'false');
    });
  }
  function next(){ show(cur+1); }
  function prev(){ show(cur-1); }
  function restart(){ clearInterval(timer); timer = setInterval(next, 5000); }
  g.querySelector('.next').addEventListener('click', function(){ next(); restart(); });
  g.querySelector('.prev').addEventListener('click', function(){ prev(); restart(); });
  dots.forEach(function(d,n){ d.addEventListener('click', function(){ show(n); restart(); }); });
  restart();
})();
</script>

